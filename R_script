```{r}


# 1. NALAGANJE POTREBNIH KNJIŽNIC
library(readxl)    # Za uvoz Excel datotek
install.packages("tidyverse")
library(tidyverse) # Za manipulacijo podatkov in vizualizacijo
install.packages("lubridate")
library(lubridate) # Za delo z datumi

# 2. UVOZ PODATKOV
file_path <- "C:/Users/.../Namizje/nadkontrola.xlsx"
data <- read_excel(file_path)

# 3. PREOBLIKOVANJE IN DODELITEV TIPOV PODATKOV
nadkontrola <- data %>%
  mutate(
    # Kategorne spremenljivke (Faktorji)
    SIFRA_LOKACIJE = as.factor(SIFRA_LOKACIJE),
    KM_ZIV_ID_SEQ  = as.factor(KM_ZIV_ID_SEQ),
    KMRM_ID_KRAVE  = as.factor(KMRM_ID_KRAVE),
    ZAP_TELITEV    = as.factor(ZAP_TELITEV),
    DEL_DNEVA      = as.factor(DEL_DNEVA),
    
    # Datumi in časi
    DATUM_KONTROLE = dmy(DATUM_KONTROLE),

    # Numerične spremenljivke
    DIM               = as.numeric(DIM),
    F_PERCENT_SAMPLE  = as.numeric(F_PERCENT_SAMPLE),
    MY_0              = as.numeric(MY_0),
    IM_0              = as.numeric(IM_0),
    MY_1              = as.numeric(MY_1),
    IM_1              = as.numeric(IM_1),
    MY_2              = as.numeric(MY_2),
    IM_2              = as.numeric(IM_2),
    MY_3              = as.numeric(MY_3)
  ) %>%
  # Odstranimo vrstice, kjer nam manjkajo ključni podatki za model M3
  filter(!is.na(IM_1), !is.na(MY_1))

# 4. PREGLED STRUKTURE
glimpse(nadkontrola)
summary(nadkontrola)

```
# čiščenje podatkov
## filtriranje podatkov: interval med molžama
```{r}
# 1. FILTRIRANJE: Obdržimo le realne intervale (npr. med 3h in 20h)
nadkontrola_clean <- nadkontrola %>%
  filter(IM_0 >= 180 & IM_0 <= 1200) %>% # Intervali med 3 in 20 urami
  filter(F_PERCENT_SAMPLE > 1.5 & F_PERCENT_SAMPLE < 9.0) # Odstranimo še biološko nerealne maščobe

```
## filtriranje podatkov: omejitev mlečnosti na en obisk robota
```{r}
# Omejimo MY_0 na biološko smiselno mejo (npr. max 35 kg na molžo)
nadkontrola_clean <- nadkontrola_clean %>%
  filter(MY_0 > 0.5 & MY_0 < 40)

# Preveriva osnovno statistiko po čiščenju
summary(nadkontrola_clean$MY_0)
```
## Omejitev predhodnega intervala pred molžo (IM_1)
```{r}
# 1. POSODOBITEV FILTRA: Omejimo še predhodni interval (IM_1)
nadkontrola_clean <- nadkontrola_clean %>%
