# Model z interakcijo med intervali molže in mlečnostjo
```{r}
# 1. GRADNJA MODELA Z INTERAKCIJAMI
# log(IM_0) * MY_0 pomeni: vpliv IM_0 + vpliv MY_0 + vpliv njunega prepleta
model_interaction <- lmer(F_PERCENT_SAMPLE ~ log(IM_0) * MY_0 + log(IM_1) * MY_1 + 
                          DIM + I(DIM^2) + ZAP_TELITEV + 
                          (1 | KM_ZIV_ID_SEQ) + (1 | SIFRA_LOKACIJE), 
                          data = nadkontrola_clean)

# 2. PREVERBA KAKOVOSTI
library(performance)
perf_interaction <- model_performance(model_interaction)
print("Rezultati modela z interakcijami:")
print(perf_interaction)

# 3. IZRAČUN RMSE
rmse_inter <- rmse(model_interaction)
print(paste("RMSE (povprečna napaka):", round(rmse_inter, 3), "% maščobe"))

# 4. PREGLED KOEFICIENTOV (da vidiva, če so interakcije značilne)
summary(model_interaction)$coefficients
```
# Cook-ova razdalja
```{r}
# 1. Izračun vpliva (Cookova razdalja) - pri 100k podatkih traja cca 1-2 min
cooks_d <- cooks.distance(model_interaction)


# 2. Odstraniva le 1 % najbolj vplivnih točk (to je znanstveno bolj vzdržno)
meja_1_procent <- quantile(cooks_d, 0.99, na.rm = TRUE)
influential_obs <- which(cooks_d > meja_1_procent)

# 3. Ustvariš nov nabor (izgubil boš le 1 % podatkov, ne 88 %)
nadkontrola_ultra <- nadkontrola_clean[-influential_obs, ]

# Preveri število vrstic - zdaj bi jih moralo biti okoli 96.900
nrow(nadkontrola_ultra)

# 4. Ponovni zagon modela
model_ultra <- lmer(F_PERCENT_SAMPLE ~ log(IM_0) * MY_0 + log(IM_1) * MY_1 + 
                    DIM + I(DIM^2) + ZAP_TELITEV + 
                    (1 | KM_ZIV_ID_SEQ) + (1 | SIFRA_LOKACIJE), 
                    data = nadkontrola_ultra)

# 5. Poglej rezultate
model_performance(model_ultra)
summary(model_ultra)

```
