# izračun korekcijskih faktorjev
```{r}
# 1. SHRANJEVANJE PARAMETROV SKALIRANJA (nujno za pravilno napoved)
# Te vrednosti potrebujemo, da nove podatke "pripravimo" na isti način kot model
means <- attr(scale(nadkontrola_ultra$MY_0), "scaled:center")
sds <- attr(scale(nadkontrola_ultra$MY_0), "scaled:scale")

# Funkcija za skaliranje novih vrednosti na podlagi baze
scale_val <- function(x, original_col) {
  (x - attr(scale(original_col), "scaled:center")) / attr(scale(original_col), "scaled:scale")
}

# 2. DEFINICIJA REFERENČNE MOLŽE (Standard: 12 ur)
# Vzamemo povprečne vrednosti črede za ostale parametre
ref_IM <- 720
ref_MY <- mean(nadkontrola_ultra$MY_0)
ref_DIM <- mean(nadkontrola_ultra$DIM)
ref_ZAP <- factor("2", levels = levels(nadkontrola_ultra$ZAP_TELITEV))

# 3. GENERIRANJE MREŽE ZA LOOKUP TABELO
# Ustvarimo različne scenarije intervalov (4h do 16h) in količin (5kg do 30kg)
grid <- expand.grid(
  IM_obs = seq(240, 960, by = 60), # od 4h do 16h
  MY_obs = seq(5, 30, by = 5)      # od 5kg do 30kg
)

# 4. IZRAČUN KOREKCIJ
grid_results <- grid %>%
  mutate(
    # Skaliranje za model
    logIM0_s = scale_val(log(IM_obs), log(nadkontrola_ultra$IM_0)),
    MY_0_s = scale_val(MY_obs, nadkontrola_ultra$MY_0),
    logIM1_s = scale_val(log(ref_IM), log(nadkontrola_ultra$IM_0)), # predpostavimo ref prejšnjo
    MY_1_s = scale_val(ref_MY, nadkontrola_ultra$MY_0),
    DIM_s = scale_val(ref_DIM, nadkontrola_ultra$DIM),
    DIM2_s = scale_val(ref_DIM^2, nadkontrola_ultra$DIM^2),
    ZAP_TELITEV = ref_ZAP
  )

# Napoved za referenco (12h) in za opazovano (grid)
pred_ref <- predict(model_final_scaled, newdata = grid_results[1,] %>% mutate(logIM0_s = scale_val(log(720), log(nadkontrola_ultra$IM_0)), MY_0_s = scale_val(ref_MY, nadkontrola_ultra$MY_0)), re.form = NA)
grid$pred_obs <- predict(model_final_scaled, newdata = grid_results, re.form = NA)

# Izračun končnega faktorja
grid$CF <- round(pred_ref - grid$pred_obs, 3)

# 5. VIZUALIZACIJA (Heatmap)
library(ggplot2)
ggplot(grid, aes(x = IM_obs/60, y = MY_obs, fill = CF)) +
  geom_tile() +
  scale_fill_gradient2(low = "red", mid = "white", high = "blue", midpoint = 0) +
  geom_text(aes(label = CF), size = 3) +
  labs(title = "Korekcijski faktorji za napoved vsebnosti maščobe (%) na osnovi enega vzorčenja",
       subtitle = "Referenca: 12-urni interval",
       x = "Interval molže (ure)",
       y = "Količina mleka pri molži (kg)",
       fill = "Popravek (+/- %)") +
  theme_minimal()
```
# validacija korekcijskih faktorjev
```{r}
# 1. NAPOVED STANDARDIZIRANE MAŠČOBE
# Za vsako vrstico izračunamo vrednost, kot da bi bil interval točno 720 min
nadkontrola_validacija <- nadkontrola_ultra %>%
  mutate(
    # Ustvarimo "fiktivne" standardne pogoje za vsako meritev
    logIM0_ref = scale_val(log(720), log(nadkontrola_ultra$IM_0)),
    MY0_ref = scale_val(mean(nadkontrola_ultra$MY_0), nadkontrola_ultra$MY_0),
    logIM1_ref = scale_val(log(720), log(nadkontrola_ultra$IM_0)),
    MY1_ref = scale_val(mean(nadkontrola_ultra$MY_0), nadkontrola_ultra$MY_0)
  )

# Izračunamo napovedano standardizirano vrednost (vključno z naključnim vplivom krave)
nadkontrola_validacija$F_CORRECTED <- predict(model_final_scaled, 
                                              newdata = nadkontrola_validacija %>% 
                                                mutate(logIM0_s = logIM0_ref, 
                                                       MY_0_s = MY0_ref,
                                                       logIM1_s = logIM1_ref,
                                                       MY_1_s = MY1_ref))

# 2. PRIMERJAVA VARIABILNOSTI
stats_raw <- sd(nadkontrola_validacija$F_PERCENT_SAMPLE)
stats_corr <- sd(nadkontrola_validacija$F_CORRECTED)

print(paste("Standardni odklon (surovi podatki):", round(stats_raw, 4)))
print(paste("Standardni odklon (popravljeni podatki):", round(stats_corr, 4)))
print(paste("Zmanjšanje variabilnosti za:", round((1 - stats_corr/stats_raw)*100, 2), "%"))

# 3. VIZUALNA VALIDACIJA (Ključni graf za članek)
library(tidyr)
plot_data <- nadkontrola_validacija %>%
  select(IM_0, F_PERCENT_SAMPLE, F_CORRECTED) %>%
  pivot_longer(cols = c(F_PERCENT_SAMPLE, F_CORRECTED), 
               names_to = "Tip", values_to = "Mascoba")

ggplot(plot_data, aes(x = IM_0, y = Mascoba, color = Tip)) +
  geom_smooth(method = "gam", se = FALSE) +
  scale_color_manual(values = c("F_CORRECTED" = "blue", "F_PERCENT_SAMPLE" = "red"),
                     labels = c("Popravljena (Standard 12h)", "Surova meritev")) +
  labs(title = "Učinek korekcije na vpliv intervala",
       x = "Interval molže (minute)",
       y = "Vsebnost maščobe (%)") +
  theme_minimal()

```
