# Model vplivov intervalov med molžama, mlečnosti DIm na % maščobe
```{r}
# Predlagana koda za naslednji korak:
install.packages("lme4")
library(lme4)
model_final <- lmer(F_PERCENT_SAMPLE ~ IM_0 + MY_0 + IM_1 + MY_1 + DIM + 
                    (1 | KM_ZIV_ID_SEQ) + (1 | SIFRA_LOKACIJE), 
                    data = nadkontrola_clean)
summary(model_final)

```
