# Cook-ova razdalja
```{r}
# 1. IzraÄŤun vpliva (Cookova razdalja) - pri 100k podatkih traja cca 1-2 min
cooks_d <- cooks.distance(model_interaction)


# 2. Odstraniva le 1 % najbolj vplivnih toÄŤk (to je znanstveno bolj vzdrĹľno)
meja_1_procent <- quantile(cooks_d, 0.99, na.rm = TRUE)
influential_obs <- which(cooks_d > meja_1_procent)

# 3. UstvariĹˇ nov nabor (izgubil boĹˇ le 1 % podatkov, ne 88 %)
nadkontrola_ultra <- nadkontrola_clean[-influential_obs, ]

# Preveri Ĺˇtevilo vrstic - zdaj bi jih moralo biti okoli 96.900
nrow(nadkontrola_ultra)

# 4. Ponovni zagon modela
model_ultra <- lmer(F_PERCENT_SAMPLE ~ log(IM_0) * MY_0 + log(IM_1) * MY_1 + 
                    DIM + I(DIM^2) + ZAP_TELITEV + 
                    (1 | KM_ZIV_ID_SEQ) + (1 | SIFRA_LOKACIJE), 
                    data = nadkontrola_ultra)

# 5. Poglej rezultate
model_performance(model_ultra)
summary(model_ultra)

```
